---
interface SkillCategory {
	category: string;
	skills: string[];
}

interface Props {
	skillCategories: SkillCategory[];
}

const { skillCategories } = Astro.props;
---

<section id="skills" class="skills" aria-labelledby="skills-heading">
	<div class="container">
		<h2 id="skills-heading">Skills</h2>
		<ul class="skills-grid" role="list">
			{skillCategories.map((category) => (
				<li class="skill-category">
					<h3 class="category-title">{category.category}</h3>
					<ul class="skill-tags" role="list">
						{category.skills.map((skill) => (
							<li class="skill-tag">{skill}</li>
						))}
					</ul>
				</li>
			))}
		</ul>
	</div>
</section>

<style>
	.skills {
		background-color: var(--color-surface);
	}

	.skills-grid {
		display: grid;
		gap: var(--spacing-sm);
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.skill-category {
		background-color: var(--color-background);
		border-radius: var(--border-radius);
		padding: var(--spacing-sm);
		border: 1px solid var(--color-border);
	}

	.category-title {
		color: var(--color-text);
		margin: 0 0 0.5rem 0;
		font-size: 0.85rem;
		font-weight: 600;
		letter-spacing: 0.02em;
		text-transform: uppercase;
	}

	.skill-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.35rem;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.skill-tag {
		display: inline-flex;
		align-items: center;
		padding: 0.3rem 0.6rem;
		background-color: rgba(96, 165, 250, 0.12);
		color: var(--color-primary);
		border-radius: 6px;
		font-size: 0.75rem;
		font-weight: 500;
		transition: all 0.15s ease;
		border: 1px solid transparent;
		list-style: none;
	}

	.skill-tag:hover {
		background-color: rgba(96, 165, 250, 0.25);
		border-color: var(--color-primary);
		transform: translateY(-1px);
	}

	@media (min-width: 400px) {
		.skill-tag {
			font-size: 0.8rem;
			padding: 0.35rem 0.7rem;
		}
	}

	@media (min-width: 480px) {
		.skills-grid {
			grid-template-columns: repeat(2, 1fr);
			gap: var(--spacing-md);
		}

		.skill-category {
			padding: var(--spacing-md);
		}

		.category-title {
			font-size: 0.9rem;
			margin-bottom: 0.75rem;
		}

		.skill-tags {
			gap: 0.5rem;
		}

		.skill-tag {
			font-size: 0.85rem;
			padding: 0.4rem 0.8rem;
		}
	}

	@media (min-width: 640px) {
		.category-title {
			font-size: 0.95rem;
		}

		.skill-tag {
			font-size: 0.9rem;
		}
	}
</style>