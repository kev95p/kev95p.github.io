---
interface ExperienceItem {
	company: string;
	role: string;
	period: string;
	location?: string;
	description?: string;
	details?: string[];
}

interface Props {
	experiences: ExperienceItem[];
}

const { experiences } = Astro.props;
---

<section id="experience" class="experience" aria-labelledby="experience-heading">
	<div class="container">
		<h2 id="experience-heading">Experience</h2>
		<ol class="timeline" role="list">
			{
				experiences.map((exp) => (
					<li class="timeline-item">
						<div class="timeline-dot" aria-hidden="true" />
						<article class="card">
							<div class="card-header">
								<div class="role-wrapper">
									<h3 class="role">{exp.role}</h3>
									<span class="company">{exp.company}</span>
								</div>
								<span class="period">{exp.period}</span>
							</div>
							{exp.location && <span class="location">{exp.location}</span>}
							{exp.description && <p class="description">{exp.description}</p>}
						{exp.details && (
							<ul class="highlights" role="list">
								{exp.details.map((detail) => (
									<li>{detail}</li>
								))}
							</ul>
						)}
						</article>
					</li>
				))
			}
		</ol>
	</div>
</section>

<style>
	.experience {
		background-color: var(--color-background);
	}

	.timeline {
		position: relative;
		padding-left: 0;
		margin: 0;
		list-style: none;
	}

	.timeline-item {
		position: relative;
		padding-left: 1.5rem;
		padding-bottom: var(--spacing-sm);
	}

	.timeline-item:last-child {
		padding-bottom: 0;
	}

	.timeline-item::before {
		content: '';
		position: absolute;
		left: 5px;
		top: 22px;
		bottom: 0;
		width: 2px;
		background-color: var(--color-border);
	}

	.timeline-item:last-child::before {
		display: none;
	}

	.timeline-dot {
		position: absolute;
		left: 0;
		top: 7px;
		width: 12px;
		height: 12px;
		border-radius: 50%;
		background-color: var(--color-primary);
		border: 2px solid var(--color-background);
	}

	.card {
		background-color: var(--color-surface);
		border-radius: var(--border-radius);
		padding: var(--spacing-sm);
		border: 1px solid var(--color-border);
	}

	.card-header {
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
		gap: var(--spacing-xs);
		flex-wrap: wrap;
	}

	.role-wrapper {
		display: flex;
		flex-direction: column;
		gap: 0.125rem;
	}

	.role {
		color: var(--color-text);
		font-size: 0.95rem;
		line-height: 1.3;
	}

	.company {
		color: var(--color-primary);
		font-weight: 500;
		font-size: 0.85rem;
	}

	.period {
		color: var(--color-text-muted);
		font-size: 0.75rem;
		white-space: nowrap;
		background-color: rgba(96, 165, 250, 0.1);
		padding: 0.125rem 0.5rem;
		border-radius: 9999px;
	}

	.location {
		color: var(--color-text-muted);
		font-size: 0.75rem;
		display: block;
		margin-top: 0.25rem;
	}

	.description {
		color: var(--color-text-muted);
		font-size: 0.8rem;
		margin-top: var(--spacing-xs);
		line-height: 1.5;
	}

	.highlights {
		margin: var(--spacing-xs) 0 0 0;
		padding-left: 1rem;
		list-style: disc;
		color: var(--color-text-muted);
		font-size: 0.8rem;
		line-height: 1.6;
	}

	.highlights li {
		margin-bottom: 0.25rem;
	}

	.highlights li:last-child {
		margin-bottom: 0;
	}

	@media (min-width: 480px) {
		.timeline-item {
			padding-left: 2rem;
		}

		.timeline-dot {
			left: 0;
			width: 12px;
			height: 12px;
		}

		.timeline-item::before {
			left: 5px;
		}
	}

	@media (min-width: 640px) {
		.card-header {
			flex-wrap: nowrap;
		}

		.role {
			font-size: 1rem;
		}

		.company {
			font-size: 0.9rem;
		}

		.period {
			font-size: 0.8rem;
		}

		.location {
			font-size: 0.8rem;
		}

		.description {
			font-size: 0.85rem;
		}

		.highlights {
			font-size: 0.85rem;
		}
	}
</style>
