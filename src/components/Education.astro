---
interface EducationItem {
	institution: string;
	degree: string;
	location: string;
	years: string;
}

interface Props {
	education: EducationItem[];
}

const { education } = Astro.props;
---

<section id="education" class="education" aria-labelledby="education-heading">
	<div class="container">
		<h2 id="education-heading">Education</h2>
		<ol class="education-list" role="list">
			{
				education.map((item) => (
					<li class="education-item">
						<article class="card">
							<div class="card-header">
								<div class="institution-wrapper">
									<h3 class="degree">{item.degree}</h3>
									<span class="institution">{item.institution}</span>
								</div>
								<span class="years">{item.years}</span>
							</div>
							<span class="location">{item.location}</span>
						</article>
					</li>
				))
			}
		</ol>
	</div>
</section>

<style>
	.education {
		background-color: var(--color-surface);
	}

	.education-list {
		margin: 0;
		padding: 0;
		list-style: none;
		display: flex;
		flex-direction: column;
		gap: var(--spacing-sm);
	}

	.card {
		background-color: var(--color-background);
		border-radius: var(--border-radius);
		padding: var(--spacing-sm);
		border: 1px solid var(--color-border);
	}

	.card-header {
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
		gap: var(--spacing-xs);
		flex-wrap: wrap;
	}

	.institution-wrapper {
		display: flex;
		flex-direction: column;
		gap: 0.125rem;
	}

	.degree {
		color: var(--color-text);
		font-size: 0.95rem;
		line-height: 1.3;
	}

	.institution {
		color: var(--color-primary);
		font-weight: 500;
		font-size: 0.85rem;
	}

	.period {
		color: var(--color-text-muted);
		font-size: 0.75rem;
		white-space: nowrap;
		background-color: rgba(96, 165, 250, 0.1);
		padding: 0.125rem 0.5rem;
		border-radius: 9999px;
	}

	.location {
		color: var(--color-text-muted);
		font-size: 0.75rem;
		display: block;
		margin-top: 0.25rem;
	}

	@media (min-width: 640px) {
		.card-header {
			flex-wrap: nowrap;
		}

		.degree {
			font-size: 1rem;
		}

		.institution {
			font-size: 0.9rem;
		}

	.years {
			font-size: 0.8rem;
		}

		.location {
			font-size: 0.8rem;
		}
	}
</style>
